# Optional OpenAI-compatible LLM settings.
# The project works without these values by using deterministic fallback logic.
AI_TEST_AGENT_USE_LLM=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Runtime defaults
AI_TEST_AGENT_OUTPUT_DIR=runs/demo
AI_TEST_AGENT_TARGET_BASE_URL=http://testserver
